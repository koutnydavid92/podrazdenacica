# Šablona pro .env - zkopíruj jako .env a doplň skutečné hodnoty.
# Soubor .env je v .gitignore a NIKDY se necommituje.

# --- Supabase (Číča Art Fest) ---
# Supabase dashboard -> tvůj projekt -> Settings -> API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Settings -> Database -> Connection string -> URI (obsahuje heslo!)
SUPABASE_DB_URL=postgresql://postgres:HESLO@db.xxxx.supabase.co:5432/postgres

# --- Stripe (doplníme ve fázi plateb) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Ecomail (doplníme ve fázi e-mailů) ---
# ECOMAIL_API_KEY=...
